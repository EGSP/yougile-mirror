{
    "version": "0.2.0",
    "configurations": [
      {
        "name": "Full launch",
        "type": "node",
        "request": "launch",
        "runtimeExecutable": "pnpm",
        "runtimeArgs": ["run", "dev"],
        "cwd": "${workspaceFolder}",
        "console": "integratedTerminal"
      },
      {
        "name": "Full launch (Debug)",
        "type": "node",
        "request": "launch",
        "runtimeExecutable": "node",
        "runtimeArgs": [
          "--inspect",
          "${workspaceFolder}/node_modules/vite/bin/vite.js",
          "dev",
          "--port",
          "3333"
        ],
        "cwd": "${workspaceFolder}",
        "console": "integratedTerminal",
        "serverReadyAction": {
          "action": "startDebugging",
          "name": "Chrome",
          "pattern": "Local:.*http://localhost:3333"
        },
        "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
      },
      {
        "name": "Chrome",
        "type": "chrome",
        "request": "launch",
        "url": "http://localhost:3333",
        "webRoot": "${workspaceFolder}/src"
      }
    ]
  }